# Copy this file to `.env` and adjust as needed, then run: docker compose up -d
# (docker compose reads .env automatically; the file is git-ignored.)

# ---- Database (PostgreSQL) ----
POSTGRES_USER=localocr
# Required — the stack refuses to start without it. Use a long random value.
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=localocr

# ---- Web ----
# Host port the app is published on -> open http://localhost:8080
LOCALOCR_PORT=8080
# Number of uvicorn workers in the backend container. 4 comfortably serves
# 10+ concurrent users; extraction itself runs in background jobs.
WEB_CONCURRENCY=4

# ---- Security ----
# Secret used to sign session cookies. Set a long random value in production.
# Generate one with:  python -c "import secrets; print(secrets.token_hex(32))"
# If left blank, the backend generates and persists one on its data volume.
LOCALOCR_SECRET_KEY=
# Set to true only when serving over HTTPS (marks the session cookie Secure).
LOCALOCR_COOKIE_SECURE=false
# Allow anyone who can reach the app to create an account. Set to false for
# invite-only: admins then add users from the Admin tab. (The very first
# account can always be created, so a fresh install can bootstrap its admin.)
LOCALOCR_ALLOW_REGISTRATION=true

# ---- Uploads & quotas ----
# Per-file upload limit (MB). nginx also caps request bodies at 100 MB.
LOCALOCR_MAX_UPLOAD_MB=50
# Total storage per user (MB): originals + rendered pages + exports.
LOCALOCR_USER_QUOTA_MB=2048
# Maximum pages per document.
LOCALOCR_MAX_PAGES=200

# ---- Vision model (Ollama) ----
LOCALOCR_MODEL=qwen2.5vl:7b
# Extraction pipeline: "vlm" (page image straight to LOCALOCR_MODEL) or
# "thai-ocr" (Typhoon OCR transcribes the page first — much more accurate for
# Thai documents; pull the model once: ollama pull scb10x/typhoon-ocr1.5-3b).
LOCALOCR_EXTRACT_MODE=vlm
LOCALOCR_TYPHOON_MODEL=scb10x/typhoon-ocr1.5-3b
# Rasterization DPI for rendered pages (higher = sharper, slower).
LOCALOCR_DPI=200
# Model context window per extraction call. A page image alone is ~4k tokens;
# raise this if extractions fail with "exceeds the available context size"
# (each increase costs GPU memory).
LOCALOCR_NUM_CTX=8192
# Layers offloaded to the GPU per request. 999 = force every layer onto the
# GPU (no CPU fallback). Lower only if a model is too large for your VRAM.
LOCALOCR_NUM_GPU=999

# ---- Logging ----
# DEBUG, INFO, WARNING or ERROR.
LOCALOCR_LOG_LEVEL=INFO
